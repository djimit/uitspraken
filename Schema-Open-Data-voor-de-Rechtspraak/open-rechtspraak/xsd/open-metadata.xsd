            <xs:annotation>
              <xs:documentation>Slowaaks</xs:documentation>
            </xs:annotation>
          </xs:enumeration>
          <xs:enumeration value="sl">
            <xs:annotation>
              <xs:documentation>Sloveens</xs:documentation>
            </xs:annotation>
          </xs:enumeration>
          <xs:enumeration value="fi">
            <xs:annotation>
              <xs:documentation>Fins</xs:documentation>
            </xs:annotation>
          </xs:enumeration>
